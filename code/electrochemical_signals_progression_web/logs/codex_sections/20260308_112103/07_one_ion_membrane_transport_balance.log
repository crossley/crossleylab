-  ctx.strokeStyle = 'rgba(120, 170, 255, 0.2)';
-  ctx.lineWidth = 1 * dpr;
-  ctx.strokeRect(0.5 * dpr, 0.5 * dpr, w - dpr, h - dpr);
-
-  const [negPx] = worldToCanvas(state.negX, 0, state, w, h);
