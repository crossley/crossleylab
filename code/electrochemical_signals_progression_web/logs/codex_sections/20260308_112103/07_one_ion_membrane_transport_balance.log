-    'drift_x = -electric_strength · (charge_wall_x - x) / (|charge_wall_x - x| + ε)',
-    'drift_y = 0',
-    'x_trial = x_old + (dxdt + drift_x) · dt',
-    'x_new = reflect(x_trial, charge_wall_x, W/2)',
-    'y_new = reflect(y_old + dydt · dt, -H/2, H/2)',
-    'dxdt, dydt ~ Normal(0, diffusionSd²)',
-    '',
